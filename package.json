{
  "name": "gestor-leads-prediagnostico",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:use:sqlite": "node -e \"require('fs').copyFileSync('prisma/schema.sqlite.prisma','prisma/schema.prisma')\" && npx prisma generate && echo ✓ SQLite activado. Para desarrollo local.",
    "db:use:postgres": "node -e \"let s=require('fs').readFileSync('prisma/schema.sqlite.prisma','utf8');s=s.replace('provider = \\\"sqlite\\\"','provider = \\\"postgresql\\\"');require('fs').writeFileSync('prisma/schema.prisma',s)\" && npx prisma generate && echo ✓ PostgreSQL activado. Para producción."
  },
