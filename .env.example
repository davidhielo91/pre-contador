# ──────────────────────────────────────────────
# Gestor de Leads - Pre-Diagnóstico IMSS
# ──────────────────────────────────────────────

# ── Base de datos ──────────────────────────────
# Desarrollo local (SQLite):
# DATABASE_URL="file:./prisma/dev.db"
#
# Producción (PostgreSQL):
# Si el password tiene caracteres especiales ($, @, &), URL-encódalos:
#   $ → %24   @ → %40   & → %26
DATABASE_URL="postgresql://usuario:contraseña@host:5432/nombre_db?sslmode=disable"

# ── Auth.js v5 ─────────────────────────────────
# IMPORTANTE: Auth.js v5 usa AUTH_SECRET y AUTH_URL (no NEXTAUTH_*)
#
# Generar secreto seguro:
#   openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="https://tu-dominio.com"

# Necesario en producción detrás de reverse proxy (EasyPanel, Nginx, etc.)
AUTH_TRUST_HOST="true"

# ── Seed de administrador ──────────────────────
# El seed sincroniza estas credenciales en cada arranque del contenedor.
# Cambiar ADMIN_PASSWORD y redesplegar actualiza la contraseña en la BD.
ADMIN_EMAIL="admin@despacho.com"
ADMIN_PASSWORD=""

# ── Notificaciones por correo (Resend) ────────
# Si se configuran, se envía un correo al llegar cada nuevo lead.
# RESEND_API_KEY: obtener en resend.com
# NOTIFICATION_EMAIL: destinatario de las alertas (si no se define, usa ADMIN_EMAIL)
# RESEND_FROM_EMAIL: remitente verificado en Resend
RESEND_API_KEY=""
NOTIFICATION_EMAIL=""
RESEND_FROM_EMAIL="noreply@contadorgerardohuerta.com"

# ── URL base del CRM ───────────────────────────
# Usada en los correos de notificación para el botón "Ver lead en el CRM".
# Si no se define, usa el dominio hardcodeado en email.ts.
NEXT_PUBLIC_BASE_URL="https://tu-dominio.com"
